{
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/google-services.json)",
      "Read(**/GoogleService-Info.plist)",
      "Read(**/key.properties)",
      "Read(**/*.keystore)",
      "Read(**/*.jks)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/google-services.json)",
      "Edit(**/GoogleService-Info.plist)",
      "Edit(**/key.properties)",
      "Edit(**/android/app/build.gradle)",
      "Edit(**/android/build.gradle)",
      "Edit(**/ios/Runner.xcodeproj/**)",
      "Edit(**/ios/Runner/Info.plist)",
      "Edit(**/ios/Podfile)",
      "Edit(pubspec.lock)",
      "Write(.env)",
      "Write(.env.*)",
      "Bash(rm -rf:*)",
      "Bash(flutter pub publish:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)"
    ],
    "ask": [
      "Edit(lib/core/utils/api_client.dart)",
      "Edit(lib/core/utils/token_manager.dart)",
      "Edit(lib/core/constants/api_constants.dart)",
      "Edit(lib/data/services/auth_service.dart)",
      "Edit(analysis_options.yaml)",
      "Bash(flutter pub remove:*)",
      "Bash(flutter pub upgrade:*)",
      "Bash(flutter build apk:*)",
      "Bash(flutter build ios:*)",
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)"
    ],
    "allow": [
      "Edit(pubspec.yaml)",
      "Edit(lib/main.dart)",
      "Edit(lib/app_router.dart)",
      "Edit(lib/core/theme/app_theme.dart)",
      "Edit(lib/features/auth/providers/auth_provider.dart)",
      "Bash(flutter pub add:*)",
      "Bash(flutter run)",
      "Bash(flutter run:*)",
      "Bash(flutter pub get)",
      "Bash(flutter test)",
      "Bash(flutter test:*)",
      "Bash(flutter analyze)",
      "Bash(flutter clean)",
      "Bash(dart format:*)",
      "Bash(dart run custom_lint)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(dir)",
      "Bash(tree:*)"
    ]
  }
}