<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Geliştirme ortamında localhost ve yerel ağa HTTP ile bağlanabilmek için -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emülatöründe host PC = 10.0.2.2 -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Localhost (fiziksel cihazda kullanılmaz ama tanımlı olsun) -->
        <domain includeSubdomains="false">localhost</domain>
        <!-- Yerel ağ IP aralığı — fiziksel cihaz için -->
        <domain includeSubdomains="false">192.168.0.0</domain>
        <domain includeSubdomains="true">192.168.1</domain>
        <domain includeSubdomains="true">192.168.0</domain>
        <domain includeSubdomains="true">10.0.0</domain>
    </domain-config>
</network-security-config>
